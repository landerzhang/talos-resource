{
  "version": 1,
  "servers": {
    "filesystem": {
      "enabled": true,
      "timeoutMs": 120000,
      "connectTimeoutMs": 60000,
      "tools": {
        "include": []
      },
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Filesystem",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/filesystem",
        "note": "Read/write files in the listed roots only. Edit args to change accessible directories."
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/landerz/Project",
        "/Users/landerz/Documents",
        "/Users/landerz/.talos"
      ],
      "env": {}
    },
    "memory": {
      "enabled": true,
      "timeoutMs": 60000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Memory (knowledge graph)",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/memory",
        "note": "Persistent knowledge graph stored at MEMORY_FILE_PATH. Independent from Talos memory."
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE_PATH": "/Users/landerz/.talos/cache/mcp-memory.json"
      }
    },
    "sequentialthinking": {
      "enabled": true,
      "timeoutMs": 60000,
      "connectTimeoutMs": 30000,
      "tools": {
        "include": []
      },
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Sequential Thinking",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/sequentialthinking",
        "note": "Step-by-step reasoning scratchpad tool."
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "everything": {
      "enabled": true,
      "timeoutMs": 60000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Everything (reference test server)",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/everything",
        "note": "Test server with prompts/resources/tools — useful for verifying MCP wiring."
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-everything"
      ],
      "env": {}
    },
    "fetch": {
      "enabled": true,
      "timeoutMs": 60000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Fetch (HTTP)",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/fetch",
        "note": "Requires uvx (brew install uv). Fetches web content and converts to LLM-friendly text."
      },
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "git": {
      "enabled": true,
      "timeoutMs": 60000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Git",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/git",
        "note": "Requires uvx (brew install uv). Repo path is pre-set to ~/project/Talos."
      },
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-git",
        "--repository",
        "/Users/landerz/project/Talos"
      ],
      "env": {}
    },
    "time": {
      "enabled": true,
      "timeoutMs": 30000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "metadata": {
        "title": "Time / Timezone",
        "source": "modelcontextprotocol/servers (official reference)",
        "homepage": "https://github.com/modelcontextprotocol/servers/tree/main/src/time",
        "note": "Requires uvx (brew install uv). Current time and timezone conversion."
      },
      "transport": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-time"
      ],
      "env": {}
    }
  }
}
