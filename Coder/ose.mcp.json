{
  "version": 1,
  "servers": {
    "Cloudfare": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "bearer",
        "tokenSource": "keychain",
        "token": "cloudflare"
      },
      "transport": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "Linear": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "oauth",
        "registration": "dcr",
        "scopes": [],
        "requestRefreshToken": true
      },
      "transport": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "Brave": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "bearer",
        "tokenSource": "keychain",
        "token": "brave-search",
        "varName": "BRAVE_API_KEY"
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ]
    },
    "generation": {
      "enabled": true,
      "timeoutMs": 600000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "bearer",
        "tokenSource": "keychain",
        "token": "dashscope-api-key",
        "varName": "DASHSCOPE_API_KEY"
      },
      "metadata": {
        "title": "文生图/文生视频 (通义万相)",
        "source": "talos",
        "note": "Bundled local generation MCP server. command/args 为变量, 由 desktop 运行时注入路径; API key 走客户端 keychain (DASHSCOPE_API_KEY)."
      },
      "transport": "stdio",
      "command": "${TALOS_MCP_GENERATION_NODE}",
      "args": [
        "${TALOS_MCP_GENERATION_SCRIPT}"
      ],
      "env": {
        "ELECTRON_RUN_AS_NODE": "1",
        "GENERATION_IMAGE_MODEL": "wanx2.1-t2i-turbo"
      }
    }
  }
}
