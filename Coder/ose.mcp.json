{
  "version": 1,
  "servers": {
    "Cloudfare": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "bearer",
        "tokenSource": "keychain",
        "token": "cloudflare"
      },
      "transport": "http",
      "url": "https://mcp.cloudflare.com/mcp"
    },
    "Linear": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "oauth",
        "registration": "dcr",
        "scopes": [],
        "requestRefreshToken": true
      },
      "transport": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "GitHub": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "oauth",
        "registration": "pre_registered",
        "clientId": "Ov23liJdZ3wxkFV1arva",
        "authorizationEndpoint": "https://github.com/login/oauth/authorize",
        "tokenEndpoint": "https://github.com/login/oauth/access_token",
        "scopes": [
          "repo",
          "read:org",
          "read:user"
        ],
        "requestRefreshToken": true
      },
      "metadata": {
        "title": "GitHub MCP Server",
        "source": "github",
        "note": "GitHub 不发布 RFC 8414 metadata 也不支持 DCR：用 pre_registered client_id + 显式端点。OAuth App 回调 URL 需设为 http://127.0.0.1:29351/oauth/callback。"
      },
      "transport": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "Brave": {
      "enabled": false,
      "timeoutMs": 120000,
      "connectTimeoutMs": 30000,
      "supportsParallelToolCalls": false,
      "auth": {
        "type": "bearer",
        "tokenSource": "keychain",
        "token": "brave-search",
        "varName": "BRAVE_API_KEY"
      },
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ]
    }
  }
}
